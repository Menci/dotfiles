{{ if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") -}}
#!/usr/bin/env bash
set -euo pipefail

# agents.toml: {{ include "dot_agents/agents.toml" | sha256sum }}
{{ if eq .chezmoi.os "linux" -}}
export PATH="${XDG_DATA_HOME:-$HOME/.local/share}/fnm:$PATH"
{{ end -}}
fnm_env="$(fnm env --shell bash)"
eval "$fnm_env"
npx --yes --prefer-online @sentry/dotagents@latest --user install
{{ end -}}
